# ============================================================
# .env.example - copie para .env e preencha com valores reais
# NUNCA commite o .env final no Git
# ============================================================

# Ambiente: "development" ou "production"
ENV=production

# JWT (gere com: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET=
JWT_EXPIRATION_MINUTES=60

# Origens autorizadas para CORS (separadas por virgula, SEM wildcard "*")
ALLOWED_ORIGINS=https://seu-dominio.com.br,https://www.seu-dominio.com.br

# Proxies reversos confiaveis (CIDR ou IPs do Nginx/Traefik/CDN)
TRUSTED_PROXIES=127.0.0.1/32

# ------------------------------------------------------------
# Provedor LLM ativo: json_only | gemini | openai | ollama | deepseek
# ------------------------------------------------------------
ACTIVE_INTERPRETER=json_only

GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_URL=http://localhost:11434/api/generate

# ------------------------------------------------------------
# Credenciais administrativas
# ADMIN_PASSWORD_HASH = hash bcrypt da senha (NUNCA a senha em texto)
# Gere com: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('SUA_SENHA'))"
# ------------------------------------------------------------
ADMIN_USER=admin@exemplo.com
ADMIN_PASSWORD_HASH=
