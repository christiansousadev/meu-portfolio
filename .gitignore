# ============================================================
# Segredos e ambiente (NUNCA versionar)
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key

# ============================================================
# Governanca do ambiente de desenvolvimento (Claude Code)
# Nao expor ao publico: contem diretrizes internas e ignore-rules
# ============================================================
CLAUDE.md
.claudeignore
.claude/

# ============================================================
# Backend - Python
# ============================================================
backend/venv/
venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Estado runtime e trilhas de auditoria (gerados pela app, nunca versionar)
backend/data/runtime_state.json
backend/data/*.jsonl

# ============================================================
# Frontend - Node/Vite
# ============================================================
frontend/node_modules/
node_modules/
frontend/dist/
dist/
build/
.vite/

# Lockfile do npm: manter no repositorio para reproducibilidade
# (NAO ignorar package-lock.json em projetos com deploy)

# ============================================================
# Logs e artefatos de execucao
# ============================================================
*.log
logs/
*.pid

# ============================================================
# Editores e SO
# ============================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Docker / CI local
# ============================================================
*.local
docker-compose.override.yml
